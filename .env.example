# ── Azure AI Search ──────────────────────────────────────────────────────────
# Query key (read-only) — used by the browser for regular search results.
# Azure portal → Search service → Settings → Keys
AZURE_SEARCH_API_KEY=

# ── Netlify Edge Function secrets (never sent to the browser) ────────────────
# Set these in Netlify UI → Site settings → Environment variables.
# Locally they are read from this file by `netlify dev`.

# Azure AI Search — admin key and connection details for the AI grounding source.
AZURE_SEARCH_ENDPOINT=

# Use a dedicated dev index locally (e.g. v6-docs-dev) so that running
# refresh-search-index.ps1 never touches the production index (v6-docs).
# To set up your dev index for the first time, set this to your dev index name
# and run: ./scripts/refresh-search-index.ps1
# CI/CD sets this to the production index name.
AZURE_SEARCH_INDEX=
AZURE_SEARCH_ADMIN_KEY=

# Azure OpenAI — used by the /api/ask-ai edge function to answer AI questions.
# Azure portal → your OpenAI resource → Keys and Endpoint
# AZURE_OPENAI_DEPLOYMENT is the model deployment name (e.g. gpt-4o).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
